<Page x:Class="ReadAndWrite.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль" Background="#EAECEE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A5276" Padding="15,12">
            <TextBlock Text="👤 Мой профиль"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="15">

                <!-- Информация о пользователе -->
                <Border Background="White" CornerRadius="4"
                        Padding="20" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Аватар -->
                        <Border Grid.Column="0" Width="80" Height="80"
                                Background="#2471A3" CornerRadius="40"
                                Margin="0,0,20,0">
                            <TextBlock Text="👤" FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Данные -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtDisplayName"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#1A5276"/>
                            <TextBlock x:Name="TxtLogin" FontSize="13"
                                       Foreground="Gray" Margin="0,4,0,4"/>
                            <TextBlock x:Name="TxtEmail" FontSize="13"
                                       Foreground="Gray"/>
                            <TextBlock x:Name="TxtRole" FontSize="13"
                                       Foreground="#1E8449" Margin="0,4,0,0"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Редактировать профиль -->
                <Border Background="White" CornerRadius="4"
                        Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Редактировать профиль"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1A5276" Margin="0,0,0,12"/>

                        <TextBlock Text="Отображаемое имя" FontSize="12"
                                   Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtNewName" Padding="7"
                                 BorderBrush="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Email" FontSize="12"
                                   Foreground="#777" Margin="0,0,0,4"/>
                        <TextBox x:Name="TxtNewEmail" Padding="7"
                                 BorderBrush="#CCC" Margin="0,0,0,10"/>

                        <TextBlock Text="Новый пароль (оставьте пустым если не меняете)"
                                   FontSize="12" Foreground="#777" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="TxtNewPassword" Padding="7"
                                     BorderBrush="#CCC" Margin="0,0,0,15"/>

                        <Button Content="Сохранить изменения"
                                Click="BtnSave_Click"
                                Background="#1E8449" Foreground="White"
                                BorderThickness="0" Padding="12,7"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Заявка на роль автора -->
                <Border x:Name="AuthorRequestPanel" Background="White"
                        CornerRadius="4" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Стать автором"
                                   FontSize="15" FontWeight="Bold"
                                   Foreground="#1A5276" Margin="0,0,0,8"/>
                        <TextBlock Text="Подайте заявку чтобы публиковать книги"
                                   FontSize="13" Foreground="#777"
                                   Margin="0,0,0,12"/>
                        <Button Content="Подать заявку"
                                Click="BtnRequestAuthor_Click"
                                Background="#2471A3" Foreground="White"
                                BorderThickness="0" Padding="12,7"
                                HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>

                <!-- Выход -->
                <Button Content="Выйти из аккаунта"
                        Click="BtnLogout_Click"
                        Background="#C0392B" Foreground="White"
                        BorderThickness="0" Padding="12,7"
                        HorizontalAlignment="Left"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>