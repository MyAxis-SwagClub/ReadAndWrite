<Page x:Class="ReadAndWrite.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог книг">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Поиск и фильтры -->
        <WrapPanel Grid.Row="0" Margin="10" Background="WhiteSmoke">
            <TextBox x:Name="TxtSearch" Width="200" Padding="6"
                     BorderBrush="Gray" BorderThickness="1"
                     Margin="5"/>
            <Button Content="Поиск" Click="BtnSearch_Click"
                    Background="SteelBlue" Foreground="White"
                    BorderThickness="0" Padding="8,6" Margin="5"/>
            <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="CmbSort" Width="130" Margin="5"
                      SelectionChanged="CmbSort_Changed">
                <ComboBoxItem Content="По названию" IsSelected="True"/>
                <ComboBoxItem Content="По оценке"/>
            </ComboBox>
            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="5"/>
            <ComboBox x:Name="CmbGenre" Width="130" Margin="5"
                      SelectionChanged="CmbGenre_Changed"/>
        </WrapPanel>

        <!-- Список книг -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel x:Name="BooksPanel" Margin="10"/>
        </ScrollViewer>
    </Grid>
</Page>