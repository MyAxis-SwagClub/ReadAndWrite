<Page x:Class="ReadAndWrite.Pages.ReadingListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Списки чтения" Background="#EAECEE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A5276" Padding="15,12">
            <TextBlock Text="📋 Мои списки чтения"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Вкладки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    Background="White" Margin="0,0,0,1">
            <Button x:Name="BtnAll" Content="Все"
                    Click="BtnFilter_Click" Tag=""
                    Background="#1A5276" Foreground="White"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button x:Name="BtnPlanned" Content="В планах"
                    Click="BtnFilter_Click" Tag="В планах"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button x:Name="BtnReading" Content="Читаю"
                    Click="BtnFilter_Click" Tag="Читаю"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button x:Name="BtnDone" Content="Прочитано"
                    Click="BtnFilter_Click" Tag="Прочитано"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button x:Name="BtnDropped" Content="Заброшено"
                    Click="BtnFilter_Click" Tag="Заброшено"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
        </StackPanel>

        <!-- Список книг -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ListPanel" Margin="15"/>
        </ScrollViewer>
    </Grid>
</Page>