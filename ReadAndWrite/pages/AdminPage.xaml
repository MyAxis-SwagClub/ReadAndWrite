<Page x:Class="ReadAndWrite.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Администрирование" Background="#EAECEE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A5276" Padding="15,12">
            <TextBlock Text="⚙ Администрирование"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Вкладки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="White">
            <Button Content="Пользователи" Click="BtnTab_Click" Tag="users"
                    Background="#1A5276" Foreground="White"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button Content="Книги" Click="BtnTab_Click" Tag="books"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button Content="Жалобы" Click="BtnTab_Click" Tag="complaints"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button Content="Заявки на автора" Click="BtnTab_Click" Tag="requests"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
            <Button Content="Отзывы" Click="BtnTab_Click" Tag="reviews"
                    Background="Transparent" Foreground="#555"
                    BorderThickness="0" Padding="15,10" FontSize="13"/>
        </StackPanel>

        <!-- Контент -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" Margin="15"/>
        </ScrollViewer>
    </Grid>
</Page>