<Page x:Class="ReadAndWrite.Pages.BookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Книга" Background="#EAECEE">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Border Grid.Row="0" Background="#1A5276" Padding="15,12">
            <StackPanel Orientation="Horizontal">
                <Button Content="❮ Назад" Click="BtnBack_Click"
                        Background="#2471A3" Foreground="White"
                        BorderThickness="0" Padding="10,5"
                        FontSize="13" Margin="0,0,15,0"/>
                <TextBlock x:Name="TxtTitle" Text="Загрузка..."
                           FontSize="18" FontWeight="Bold"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="15">

                <!-- Верхний блок: инфо слева, форма отзыва справа -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="320"/>
                    </Grid.ColumnDefinitions>

                    <!-- Информация о книге -->
                    <Border Grid.Column="0" Background="White"
                            CornerRadius="4" Padding="15"
                            Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock x:Name="TxtAuthor" FontSize="15"
                                       FontWeight="Bold" Foreground="#1A5276"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtGenres" FontSize="13"
                                       Foreground="#888" Margin="0,0,0,8"/>
                            <TextBlock x:Name="TxtRating" FontSize="20"
                                       Margin="0,0,0,12"/>
                            <TextBlock x:Name="TxtDescription" FontSize="13"
                                       TextWrapping="Wrap" Foreground="#444"
                                       Margin="0,0,0,20"/>

                            <!-- Список чтения внизу карточки -->
                            <TextBlock Text="Добавить в список чтения:"
                                       FontSize="12" Foreground="#777"
                                       Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="CmbReadingList" Width="160"
                                          Margin="0,0,8,0" Padding="5">
                                    <ComboBoxItem Content="Выберите раздел"/>
                                    <ComboBoxItem Content="В планах"/>
                                    <ComboBoxItem Content="Читаю"/>
                                    <ComboBoxItem Content="Прочитано"/>
                                    <ComboBoxItem Content="Заброшено"/>
                                </ComboBox>
                                <Button Content="✔ Сохранить"
                                        Click="BtnAddToList_Click"
                                        Background="#1E8449" Foreground="White"
                                        BorderThickness="0" Padding="10,5"/>

                                
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Форма отзыва справа -->
                    <Border Grid.Column="1" Background="White"
                            CornerRadius="4" Padding="15">
                        <StackPanel>
                            <TextBlock Text="✏ Написать отзыв"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#1A5276" Margin="0,0,0,10"/>
                            <TextBox x:Name="TxtReview" Height="100"
                                     TextWrapping="Wrap" AcceptsReturn="True"
                                     Padding="7" BorderBrush="#CCC"
                                     Margin="0,0,0,10"/>
                            <TextBlock Text="Оценка от 1 до 10:"
                                       FontSize="12" Foreground="#777"
                                       Margin="0,0,0,6"/>
                            <ComboBox x:Name="CmbRating" Width="80"
                                      Padding="5" Margin="0,0,0,12"
                                      HorizontalAlignment="Left">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="6"/>
                                <ComboBoxItem Content="7"/>
                                <ComboBoxItem Content="8"/>
                                <ComboBoxItem Content="9"/>
                                <ComboBoxItem Content="10"/>
                            </ComboBox>
                            <Button Content="Отправить отзыв"
                                    Click="BtnSendReview_Click"
                                    Background="#2471A3" Foreground="White"
                                    BorderThickness="0" Padding="10,7"
                                    HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                </Grid>
                <!-- Жалоба на книгу -->
                <Button Content="⚠ Пожаловаться на книгу"
        Click="BtnComplaint_Click"
        Background="#E74C3C" Foreground="White"
        BorderThickness="0" Padding="10,5"
        HorizontalAlignment="Left"
        Margin="0,10,0,0"/>

                <!-- Отзывы снизу -->
                <TextBlock Text="💬 Отзывы читателей" FontSize="15"
                           FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="#1A5276"/>
                <StackPanel x:Name="ReviewsPanel"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>