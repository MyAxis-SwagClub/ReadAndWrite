<Page x:Class="ReadAndWrite.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход" Height="320" Width="391">

    <Grid Background="White">
        <StackPanel Width="300" VerticalAlignment="Center" HorizontalAlignment="Center">

            <TextBlock Text="Читай, Пиши и не спиши"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Кнопки переключения -->
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnLoginTab" Content="Вход"
                        Grid.Column="0" Click="BtnLoginTab_Click"
                        Background="SteelBlue" Foreground="White"
                        BorderThickness="0" Padding="8"/>
                <Button x:Name="BtnRegisterTab" Content="Регистрация"
                        Grid.Column="1" Click="BtnRegisterTab_Click"
                        Background="LightGray" Foreground="Black"
                        BorderThickness="0" Padding="8"/>
            </Grid>

            <!-- Панель входа -->
            <StackPanel x:Name="LoginPanel">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtLogin" Padding="6" Margin="0,0,0,10"
                         BorderBrush="Gray" BorderThickness="1"/>

                <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtPassword" Padding="6" Margin="0,0,0,15"
                             BorderBrush="Gray" BorderThickness="1"/>

                <Button Content="Войти" Click="BtnLogin_Click"
                        Background="SteelBlue" Foreground="White"
                        BorderThickness="0" Padding="10" FontSize="14"/>
            </StackPanel>

            <!-- Панель регистрации -->
            <StackPanel x:Name="RegisterPanel" Visibility="Collapsed">
                <TextBlock Text="Логин" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegLogin" Padding="6" Margin="0,0,0,10"
                         BorderBrush="Gray" BorderThickness="1"/>

                <TextBlock Text="Отображаемое имя" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegName" Padding="6" Margin="0,0,0,10"
                         BorderBrush="Gray" BorderThickness="1"/>

                <TextBlock Text="Email" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegEmail" Padding="6" Margin="0,0,0,10"
                         BorderBrush="Gray" BorderThickness="1"/>

                <TextBlock Text="Пароль" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtRegPassword" Padding="6" Margin="0,0,0,15"
                             BorderBrush="Gray" BorderThickness="1"/>

                <Button Content="Зарегистрироваться" Click="BtnRegister_Click"
                        Background="SteelBlue" Foreground="White"
                        BorderThickness="0" Padding="10" FontSize="14"/>
            </StackPanel>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="TxtError" Foreground="Red"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" TextWrapping="Wrap"/>

        </StackPanel>
    </Grid>
</Page>